# Discord Webhooks
DISCORD_WEBHOOK_FEDERAL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_SCOTUS=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# CourtListener API Token (REQUIRED for 5,000 req/hr - free signup)
# Get one at: https://www.courtlistener.com/sign-in/
COURTLISTENER_API_TOKEN=your-token-here

# Check interval in seconds (10 = fastest safe, each source checked every 60s)
CHECK_INTERVAL=10
